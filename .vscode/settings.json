{
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "files.exclude": {
    "**/build": true,
    "**/DerivedData": true,
    "**/.DS_Store": true,
    "**/xcuserdata": true,
    "**/__pycache__": true,
    "proof-of-work": true
  },
  "search.exclude": {
    "**/build": true,
    "**/DerivedData": true,
    "**/*.xcodeproj/project.pbxproj": true,
    "**/lottie_downloads/*.json": true
  },
  "files.associations": {
    "*.xcconfig": "properties",
    "*.entitlements": "xml",
    "*.plist": "xml"
  },
  "[swift]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  }
}
